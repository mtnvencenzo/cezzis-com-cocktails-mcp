
// ------------------------------------------------------------
// Get Ping
// ------------------------------------------------------------
GET {{host}}/mcp/v1/health/ping
Accept: application/json

###

// ------------------------------------------------------------
// Get Version
// ------------------------------------------------------------
GET {{host}}/mcp/v1/health/version
Accept: application/json

###

// ------------------------------------------------------------
// Get Readiness
// ------------------------------------------------------------
GET {{host}}/mcp/v1/health/readiness
Accept: application/json

###

// ------------------------------------------------------------
// Get Liveness
// ------------------------------------------------------------
GET {{host}}/mcp/v1/health/liveness
Accept: application/json

###

// ------------------------------------------------------------
// Initialize Request
// ------------------------------------------------------------

POST {{host}}/mcp/v1/mcp
Accept: application/json
Content-Type: application/json

{
  "jsonrpc": "2.0",
  "id": 0,
  "method": "initialize",
  "params": {
    "protocolVersion": "2025-06-18",
    "capabilities": {},
    "clientInfo": {
      "name": "cocktails-dot-http-file",
      "version": "1.0.0"
    }
  }
}

###

// ------------------------------------------------------------
// Mcp Tools List
// ------------------------------------------------------------

POST {{host}}/mcp/v1/mcp
Accept: application/json
Content-Type: application/json
Mcp-Session-Id: mcp-session-a94254f7-0378-45d1-822f-efcea775a5a8

{
  "jsonrpc": "2.0",
  "id": "1",
  "method": "tools/list",
  "params": {}
}

