
// ------------------------------------------------------------
// Get Healthz
// ------------------------------------------------------------

GET {{host}}/healthz
Accept: application/json

###

// ------------------------------------------------------------
// Get Version
// ------------------------------------------------------------

GET {{host}}/version
Accept: application/json

###

// ------------------------------------------------------------
// POST Remove Special JSON Characters
// ------------------------------------------------------------

POST {{host}}/mcp
Accept: application/json
Content-Type: application/json
Mcp-Session-Id: mcp-session-a94254f7-0378-45d1-822f-efcea775a5a8

{
  "jsonrpc": "2.0",
  "id": "1",
  "method": "tools/call",
  "params": {
    "name": "remove_special_json_characters",
    "arguments": {
      "content": "This is a test message with special JSON characters: { \"key\": \"value\" }, [1, 2, 3], and \\ backslashes."
    }
  }
}

###
